         </property>
         <property name="text">
          <string>分块大小</string>
         </property>
        </widget>
       </item>
       <item row="9" column="2">
        <widget class="QCheckBox" name="autocontrastBox">
         <property name="toolTip">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;未勾选 - 仅黑白&lt;br/&gt;&lt;/span&gt;仅对黑白页面自动对比度。对于没有接近黑白的页面将被忽略。&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;部分勾选 - 禁用&lt;br/&gt;&lt;/span&gt;禁用自动对比度&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;已勾选 - 黑白和彩色&lt;br/&gt;&lt;/span&gt;黑白和彩色图像将自动对比度。对于没有接近黑白的页面将被忽略。&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
         </property>
         <property name="text">
          <string>自动对比度</string>
         </property>
         <property name="tristate">
          <bool>true</bool>
         </property>
        </widget>
       </item>
